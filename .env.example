# ============================================================
# Horse Racing Predictor — API Credentials
# ============================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
#
# You only need ONE of these API sources. Both have free tiers.
# ============================================================

# --- The Racing API (recommended) ---
# Sign up free: https://www.theracingapi.com
# Free tier: daily racecards + results for UK & Ireland
RACING_API_USERNAME=
RACING_API_PASSWORD=

# --- RapidAPI Horse Racing (alternative) ---
# Sign up free: https://rapidapi.com/ortegalex/api/horse-racing
# Free tier: 50 requests/day, UK & Ireland racecards + results
RAPIDAPI_KEY=
